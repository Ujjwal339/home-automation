#include <ArduinoIoTCloud.h>
#include <Arduino_ConnectionHandler.h>
#include <DHT.h>
#include <IRremote.h>

/* ===================== WiFi & Cloud Credentials ===================== */

const char DEVICE_LOGIN_NAME[] = "YOUR_DEVICE_ID";
const char SSID[]              = "YOUR_WIFI_NAME";
const char PASS[]              = "YOUR_WIFI_PASSWORD";
const char DEVICE_KEY[]        = "YOUR_SECRET_DEVICE_KEY";

/* ===================== Pin Definitions ===================== */

#define DHT_PIN            4
#define IR_RECEIVER_PIN    35
#define WIFI_LED_PIN       2

// Relay Pins
#define RELAY_1_PIN        23
#define RELAY_2_PIN        19
#define RELAY_3_PIN        18
#define RELAY_4_PIN        5

// Manual Switch Pins
#define SWITCH_1_PIN       13
#define SWITCH_2_PIN       12
#define SWITCH_3_PIN       14
#define SWITCH_4_PIN       27

/* ===================== Sensor Configuration ===================== */

#define DHT_TYPE DHT11

DHT dht(DHT_PIN, DHT_TYPE);
IRrecv irReceiver(IR_RECEIVER_PIN);
decode_results irResults;

/* ===================== Relay States ===================== */

bool relayState1 = false;
bool relayState2 = false;
bool relayState3 = false;
bool relayState4 = false;

/* ===================== Switch States ===================== */

bool switchState1 = HIGH;
bool switchState2 = HIGH;
bool switchState3 = HIGH;
bool switchState4 = HIGH;

/* ===================== Sensor Variables ===================== */

float temperatureValue = 0.0;
float humidityValue = 0.0;

/* ===================== Arduino IoT Cloud Variables ===================== */

CloudSwitch light1;
CloudSwitch light2;
CloudSwitch light3;
CloudSwitch light4;

CloudTemperatureSensor temperature;

/* ===================== Function Declarations ===================== */

void onLight1Change();
void onLight2Change();
void onLight3Change();
void onLight4Change();

void initializeRelays();
void updateSensorData();
void handleIRRemote();
void handleManualSwitches();
void setRelayState(uint8_t relayPin, bool state);
void toggleRelay(uint8_t relayNumber);

/* ===================== IoT Cloud Properties ===================== */

void initProperties() {

  ArduinoCloud.setBoardId(DEVICE_LOGIN_NAME);
  ArduinoCloud.setSecretDeviceKey(DEVICE_KEY);

  ArduinoCloud.addProperty(light1, READWRITE, ON_CHANGE, onLight1Change);
  ArduinoCloud.addProperty(light2, READWRITE, ON_CHANGE, onLight2Change);
  ArduinoCloud.addProperty(light3, READWRITE, ON_CHANGE, onLight3Change);
  ArduinoCloud.addProperty(light4, READWRITE, ON_CHANGE, onLight4Change);

  ArduinoCloud.addProperty(temperature, READ, 5 * SECONDS, NULL);
}

WiFiConnectionHandler ArduinoIoTPreferredConnection(SSID, PASS);

/* ===================== Setup ===================== */

void setup() {

  Serial.begin(115200);
  delay(1500);

  pinMode(RELAY_1_PIN, OUTPUT);
  pinMode(RELAY_2_PIN, OUTPUT);
  pinMode(RELAY_3_PIN, OUTPUT);
  pinMode(RELAY_4_PIN, OUTPUT);

  pinMode(SWITCH_1_PIN, INPUT_PULLUP);
  pinMode(SWITCH_2_PIN, INPUT_PULLUP);
  pinMode(SWITCH_3_PIN, INPUT_PULLUP);
  pinMode(SWITCH_4_PIN, INPUT_PULLUP);

  pinMode(WIFI_LED_PIN, OUTPUT);

  initializeRelays();

  dht.begin();
  irReceiver.enableIRIn();

  initProperties();

  ArduinoCloud.begin(ArduinoIoTPreferredConnection);

  setDebugMessageLevel(2);
  ArduinoCloud.printDebugInfo();

  Serial.println("\n====================================");
  Serial.println("ESP32 Smart Home Automation Started");
  Serial.println("====================================");
}

/* ===================== Main Loop ===================== */

void loop() {

  ArduinoCloud.update();

  handleManualSwitches();
  handleIRRemote();
  updateSensorData();
}

/* ===================== Relay Initialization ===================== */

void initializeRelays() {

  // Active LOW Relay Logic
  digitalWrite(RELAY_1_PIN, HIGH);
  digitalWrite(RELAY_2_PIN, HIGH);
  digitalWrite(RELAY_3_PIN, HIGH);
  digitalWrite(RELAY_4_PIN, HIGH);
}

/* ===================== Sensor Handling ===================== */

void updateSensorData() {

  static unsigned long previousMillis = 0;
  const long interval = 3000;

  unsigned long currentMillis = millis();

  if (currentMillis - previousMillis >= interval) {

    previousMillis = currentMillis;

    float humidity = dht.readHumidity();
    float temperatureReading = dht.readTemperature();

    if (isnan(humidity) || isnan(temperatureReading)) {

      Serial.println("DHT11 Sensor Read Failed");
      return;
    }

    humidityValue = humidity;
    temperatureValue = temperatureReading;

    temperature = temperatureValue;

    Serial.print("Temperature: ");
    Serial.print(temperatureValue);
    Serial.println(" °C");

    Serial.print("Humidity: ");
    Serial.print(humidityValue);
    Serial.println(" %");
  }
}

/* ===================== IR Remote Control ===================== */

void handleIRRemote() {

  if (irReceiver.decode(&irResults)) {

    switch (irResults.value) {

      case 0x80BF49B6:
        toggleRelay(1);
        light1 = relayState1;
        break;

      case 0x80BFC936:
        toggleRelay(2);
        light2 = relayState2;
        break;

      case 0x80BF33CC:
        toggleRelay(3);
        light3 = relayState3;
        break;

      case 0x80BF718E:
        toggleRelay(4);
        light4 = relayState4;
        break;

      default:
        break;
    }

    irReceiver.resume();
  }
}

/* ===================== Manual Switch Handling ===================== */

void handleManualSwitches() {

  bool currentSwitch1 = digitalRead(SWITCH_1_PIN);
  bool currentSwitch2 = digitalRead(SWITCH_2_PIN);
  bool currentSwitch3 = digitalRead(SWITCH_3_PIN);
  bool currentSwitch4 = digitalRead(SWITCH_4_PIN);

  if (currentSwitch1 != switchState1) {

    delay(50);

    if (digitalRead(SWITCH_1_PIN) == currentSwitch1) {

      toggleRelay(1);
      light1 = relayState1;
      switchState1 = currentSwitch1;
    }
  }

  if (currentSwitch2 != switchState2) {

    delay(50);

    if (digitalRead(SWITCH_2_PIN) == currentSwitch2) {

      toggleRelay(2);
      light2 = relayState2;
      switchState2 = currentSwitch2;
    }
  }

  if (currentSwitch3 != switchState3) {

    delay(50);

    if (digitalRead(SWITCH_3_PIN) == currentSwitch3) {

      toggleRelay(3);
      light3 = relayState3;
      switchState3 = currentSwitch3;
    }
  }

  if (currentSwitch4 != switchState4) {

    delay(50);

    if (digitalRead(SWITCH_4_PIN) == currentSwitch4) {

      toggleRelay(4);
      light4 = relayState4;
      switchState4 = currentSwitch4;
    }
  }
}

/* ===================== Relay Control ===================== */

void toggleRelay(uint8_t relayNumber) {

  switch (relayNumber) {

    case 1:
      relayState1 = !relayState1;
      setRelayState(RELAY_1_PIN, relayState1);

      Serial.print("Relay 1: ");
      Serial.println(relayState1 ? "ON" : "OFF");
      break;

    case 2:
      relayState2 = !relayState2;
      setRelayState(RELAY_2_PIN, relayState2);

      Serial.print("Relay 2: ");
      Serial.println(relayState2 ? "ON" : "OFF");
      break;

    case 3:
      relayState3 = !relayState3;
      setRelayState(RELAY_3_PIN, relayState3);

      Serial.print("Relay 3: ");
      Serial.println(relayState3 ? "ON" : "OFF");
      break;

    case 4:
      relayState4 = !relayState4;
      setRelayState(RELAY_4_PIN, relayState4);

      Serial.print("Relay 4: ");
      Serial.println(relayState4 ? "ON" : "OFF");
      break;
  }
}

void setRelayState(uint8_t relayPin, bool state) {

  // Active LOW Relay Logic
  digitalWrite(relayPin, state ? LOW : HIGH);
}

/* ===================== Arduino IoT Cloud Callbacks ===================== */

void onLight1Change() {

  relayState1 = light1;
  setRelayState(RELAY_1_PIN, relayState1);

  Serial.print("Cloud Control Relay 1: ");
  Serial.println(relayState1 ? "ON" : "OFF");
}

void onLight2Change() {

  relayState2 = light2;
  setRelayState(RELAY_2_PIN, relayState2);

  Serial.print("Cloud Control Relay 2: ");
  Serial.println(relayState2 ? "ON" : "OFF");
}

void onLight3Change() {

  relayState3 = light3;
  setRelayState(RELAY_3_PIN, relayState3);

  Serial.print("Cloud Control Relay 3: ");
  Serial.println(relayState3 ? "ON" : "OFF");
}

void onLight4Change() {

  relayState4 = light4;
  setRelayState(RELAY_4_PIN, relayState4);

  Serial.print("Cloud Control Relay 4: ");
  Serial.println(relayState4 ? "ON" : "OFF");
}
